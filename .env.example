EDITIAN_FRONTEND_PORT=3000
EDITIAN_BACKEND_PORT=8000
EDITIAN_LOG_LEVEL=INFO
EDITIAN_LOG_FORMAT=text
EDITIAN_LOG_TO_FILE=true
